generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  username         String            @unique
  passwordHash     String?
  googleId         String?           @unique
  age              Int?
  avatarConfig     Json              @default("{}")
  tier             Tier              @default(FREE)
  totalXP          Int               @default(0)
  level            Int               @default(1)
  streakDays       Int               @default(0)
  lastActiveAt     DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  guildMemberships GuildMember[]
  helpAnswers      HelpAnswer[]
  helpPosts        HelpPost[]
  refreshTokens    RefreshToken[]
  subscription     Subscription?
  achievements     UserAchievement[]
  progress         UserProgress[]
  subjectXP        UserSubjectXP[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Subject {
  id          String          @id @default(cuid())
  name        String          @unique
  slug        String          @unique
  description String
  iconUrl     String?
  color       String          @default("#2E86AB")
  storyWorld  String
  isFree      Boolean         @default(false)
  orderIndex  Int             @default(0)
  createdAt   DateTime        @default(now())
  seasons     Season[]
  userXP      UserSubjectXP[]

  @@map("subjects")
}

model Season {
  id          String    @id @default(cuid())
  subjectId   String
  title       String
  description String
  storyArc    String
  orderIndex  Int       @default(0)
  isFree      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  chapters    Chapter[]
  subject     Subject   @relation(fields: [subjectId], references: [id])

  @@map("seasons")
}

model Chapter {
  id               String         @id @default(cuid())
  seasonId         String
  title            String
  conceptTaught    String
  storyContent     Json
  technicalContent Json
  orderIndex       Int            @default(0)
  xpReward         Int            @default(50)
  isFree           Boolean        @default(false)
  createdAt        DateTime       @default(now())
  challenges       Challenge[]
  season           Season         @relation(fields: [seasonId], references: [id])
  helpPosts        HelpPost[]
  progress         UserProgress[]

  @@map("chapters")
}

model Challenge {
  id          String             @id @default(cuid())
  chapterId   String
  title       String
  description String
  type        ChallengeType      @default(MINI)
  prompt      String
  starterCode String             @default("")
  solution    String
  testCases   Json
  xpReward    Int                @default(25)
  orderIndex  Int                @default(0)
  createdAt   DateTime           @default(now())
  attempts    ChallengeAttempt[]
  chapter     Chapter            @relation(fields: [chapterId], references: [id])

  @@map("challenges")
}

model UserSubjectXP {
  id        String  @id @default(cuid())
  userId    String
  subjectId String
  xp        Int     @default(0)
  level     Int     @default(1)
  subject   Subject @relation(fields: [subjectId], references: [id])
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@map("user_subject_xp")
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String
  completedAt DateTime @default(now())
  mode        Mode     @default(STORY)
  score       Int      @default(0)
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@map("user_progress")
}

model ChallengeAttempt {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  code        String
  passed      Boolean   @default(false)
  output      String?
  xpEarned    Int       @default(0)
  attemptedAt DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@map("challenge_attempts")
}

model Achievement {
  id          String            @id @default(cuid())
  name        String            @unique
  description String
  badgeUrl    String?
  xpReward    Int               @default(0)
  condition   Json
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Guild {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  emblemUrl   String?
  totalXP     Int           @default(0)
  createdAt   DateTime      @default(now())
  members     GuildMember[]

  @@map("guilds")
}

model GuildMember {
  id       String    @id @default(cuid())
  guildId  String
  userId   String
  role     GuildRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  guild    Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("guild_members")
}

model HelpPost {
  id         String       @id @default(cuid())
  userId     String
  chapterId  String?
  title      String
  body       String
  voteCount  Int          @default(0)
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  answers    HelpAnswer[]
  chapter    Chapter?     @relation(fields: [chapterId], references: [id])
  user       User         @relation(fields: [userId], references: [id])

  @@map("help_posts")
}

model HelpAnswer {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  body       String
  voteCount  Int      @default(0)
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  post       HelpPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@map("help_answers")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Tier {
  FREE
  VIP
}

enum ChallengeType {
  MINI
  MISSION
  BOSS
}

enum Mode {
  STORY
  TECHNICAL
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}
